# Пример конфигурации для make-agent (корень репозитория).
# Скопируйте в .env и заполните секреты:
#   cp .env.example .env
#
# Загрузка: python-dotenv в llm.py читает .env при импорте llm.
# Цвета в консоли agent.py отключаются, если stdout не TTY или задано NO_COLOR=1 (стандарт de facto).

# ---------------------------------------------------------------------------
# LLM_BACKEND — какой бэкенд вызывает agent → llm.complete()
# Значения: ollama | vsegpt
# По умолчанию в коде: ollama
# ---------------------------------------------------------------------------
LLM_BACKEND=ollama

# ---------------------------------------------------------------------------
# Ollama (POST {OLLAMA_BASE_URL}/api/chat)
# ---------------------------------------------------------------------------
# URL без завершающего слэша, например http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Имя модели в Ollama, например qwen2.5-coder:3b
# По умолчанию в коде: smollm2:1.7b
OLLAMA_MODEL=qwen2.5-coder:3b

# Таймаут HTTP-запроса к Ollama, секунды (ожидание полного ответа; удалённый сервер + tools + длинный промпт часто >120)
# По умолчанию в коде: 300
OLLAMA_TIMEOUT=300

# Системный промпт по умолчанию читается из agent_system_prompt.md (рядом с llm.py).
# Другой файл: относительный путь от каталога llm.py или абсолютный.
# AGENT_SYSTEM_PROMPT_FILE=
# Переопределить текст целиком одной строкой из .env (редко; многострочно неудобно):
# OLLAMA_SYSTEM_PROMPT=

# ---------------------------------------------------------------------------
# VseGPT (OpenAI-совместимый chat/completions)
# Используется при LLM_BACKEND=vsegpt
# ---------------------------------------------------------------------------
# Обязательно для vsegpt: ключ API
VSEGPT_API_KEY=

# URL completions
# По умолчанию в коде: https://api.vsegpt.ru/v1/chat/completions
VSEGPT_API_URL=https://api.vsegpt.ru/v1/chat/completions

# Идентификатор модели на стороне VseGPT
# По умолчанию в коде: openai/gpt-4o-mini
VSEGPT_MODEL=openai/gpt-4o-mini

# Системный промпт (по умолчанию тот же, что и для Ollama — DEFAULT_AGENT_SYSTEM_PROMPT в llm.py)
# VSEGPT_SYSTEM_PROMPT=

# Ретраи при HTTP 429
# По умолчанию в коде: 5
VSEGPT_MAX_RETRIES=5

# Базовая задержка backoff, секунды
# По умолчанию в коде: 1.0
VSEGPT_RETRY_BASE_SECONDS=1.0

# Потолок задержки (и для Retry-After), секунды
# По умолчанию в коде: 20.0
VSEGPT_RETRY_MAX_SECONDS=20.0

# ---------------------------------------------------------------------------
# Инструменты (tools.py)
# ---------------------------------------------------------------------------
# Разрешить инструмент bash (shell). По умолчанию выключено (0).
# Значение 1 включает выполнение команд — опасно, обходит ограничение «только project/».
# По умолчанию в коде: 0
TOOLS_ALLOW_BASH=0
